# Zig Task Manager Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ===== DATABASE (SurrealDB) =====
SURREAL_URL=http://127.0.0.1:8000
SURREAL_NS=taskapp
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# ===== EMAIL (Brevo API) =====
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-api-key-here
FROM_EMAIL=noreply@example.com
FROM_NAME=Zig Task Manager

# ===== APPLICATION =====
# Server configuration
PORT=9000
INTERFACE=127.0.0.1
# Use 0.0.0.0 for Docker (to accept external connections)

# CORS origin - use * for development, specific domain for production
CORS_ORIGIN=https://task.micutu.com

# Legacy Secret (for migration of old passwords)
# ⚠️ CRITICAL: In production, this MUST be set to a unique secret value!
#    The application will PANIC if not set in release mode.
LEGACY_SECRET=zig-task-manager-secret-2024
