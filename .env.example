# Zig Task Manager Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ===== DATABASE (SurrealDB) =====
SURREAL_URL=http://127.0.0.1:8000
SURREAL_NS=taskapp
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# ===== EMAIL (Brevo API) =====
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-api-key-here
FROM_EMAIL=noreply@example.com
FROM_NAME=Zig Task Manager

# ===== APPLICATION =====
# Server configuration
PORT=9000
INTERFACE=127.0.0.1
# Use 0.0.0.0 for Docker (to accept external connections)

# Public base URL of the app (used in password-reset email links).
# Must match the origin users hit in their browser.
APP_BASE_URL=https://task.micutu.com

# HSTS max-age in seconds. Enable ONLY in production behind HTTPS.
# Recommended: 31536000 (1 year). Leave unset for http:// dev.
# HSTS_MAX_AGE=31536000

# CORS origin - use * for development, specific domain for production
CORS_ORIGIN=https://task.micutu.com

# Trusted proxy IPs (comma-separated). Only these peers may set X-Real-IP /
# X-Forwarded-For to override the rate-limit client IP. Leave empty if you
# expose the server directly (not recommended).
TRUST_PROXY=127.0.0.1,::1

# Legacy Secret — ONLY needed if you have old FNV-1a password hashes in the DB
# from a pre-Argon2 install. Leave unset for new deployments.
# If you do need it, generate a unique value: `openssl rand -hex 32`
# LEGACY_SECRET=
